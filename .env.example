# Copy to .env.local (gitignored) and fill values.
# Never commit real credentials.

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# eBay Browse API (OAuth2 client_credentials)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_GB

# AliExpress Open Platform
ALIEXPRESS_APP_KEY=
ALIEXPRESS_APP_SECRET=

# Amazon Product Advertising API 5
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_ASSOCIATE_TAG=
AMAZON_MARKETPLACE=www.amazon.es

# Mercado Livre
MERCADOLIVRE_APP_ID=
MERCADOLIVRE_CLIENT_SECRET=

# Firecrawl (ad-hoc research, free tier)
FIRECRAWL_API_KEY=

# Discord webhooks
DISCORD_WEBHOOK_ALERTS=
DISCORD_WEBHOOK_DIGEST=

# KidsFashionClub catalog sync
KIDSFASHION_SEED_URL=https://raw.githubusercontent.com/MiguelReisRepo/KidsFashionClub/main/src/data/seed.ts

# Runtime
NODE_ENV=development
LOG_LEVEL=info
DRY_RUN=false
